#!/bin/bash

vg_verify() {
   valgrind --version
   valgrind --tool=memcheck --leak-check=full --track-origins=no --errors-for-leak-kinds=definite,indirect,possible --error-exitcode=1 $1
   return $?
}

db_init() {
   PARAMS="--ssl=0 -u supla -h $DBHOST"
   if ! (echo "" | mysql $PARAMS) 2> /dev/null; then
      if ! mysql $PARAMS < sql/CreateSqlUsersForTestPurposes.sql 2> /dev/null; then
         if ! mysql -u root -proot -h $DBHOST < sql/CreateSqlUsersForTestPurposes.sql 2> /dev/null; then
         echo "Enter mariadb root password.";
         mysql -u root -h $DBHOST -p < sql/CreateSqlUsersForTestPurposes.sql
         fi
      fi
   fi

   mysql $PARAMS < sql/RecreateTestDatabase.sql
   mysql $PARAMS supla_test < sql/TestDatabaseStructureAndData.sql
}
